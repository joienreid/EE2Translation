                        </node>
                    </children>
                </node>
                <node id="Quest">
                    <attribute id="CategoryID" value="EE_Tutorial" type="22" />
                    <attribute id="MainQuest" value="0" type="19" />
                    <attribute id="QuestBroadcastLevel" value="2" type="1" />
                    <attribute id="QuestID" value="EE_SourceInfusion" type="22" />
                    <attribute id="QuestTitle" value="Генерация и насыщение Истоком" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                    <attribute id="Shareable" value="1" type="19" />
                    <attribute id="SortingPriority" value="0" type="4" />
                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value='Насыщение Истоком в Epic Encounters - это переработанная система взаимодействия с очками Истока. Почти каждая способность была изменена и теперь имеет вплоть до 3 уровней усилений (насыщений). Эти "насыщения" дают дополнительные и, порой, весьма значительные и уникальные бонусы к эффекту примененной способности.&lt;br&gt;&lt;br&gt;Для усиления заклинаний используется способность "Насыщение Истоком" (получается после снятия ошейника), которая доступна только в бою и не имеет перезарядки - нажимайте на нее необходимое количество раз, перед применением способности, которую вы хотите "насытить" Истоком (насыщения ограничены вашими текущими очками Истока и обнуляются при полном цикле нажатий). При насыщениях 2 и 3 уровня вы также получаете все предыдущие бонусы насыщений (кроме бонусов где написано: "Вместо предыдущих бонусов насыщения Истоком").&lt;br&gt;&lt;br&gt;"Генерация Истока" в Epic Encounters - это измененная система получения Истока. Вне боя теперь вы не можете использовать ваш Исток, он доступен только в бою. Очки Истока обнуляются при входе в битву, и вы получаете эффект "Генерация Истока", которая, начиная со второго хода дает вам по 1 очку Истока на протяжении 3 ходов (по умолчанию).&lt;br&gt;&lt;br&gt;"Генерация Истока" становится на паузу при полном количестве очков Истока. Длительность и вариация генерации может быть значительно усилена бонусами Вознесения, предметов, способностей и Артефактов.' handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="DevComment" value="" type="22" />
                            <attribute id="Gain" value="0" type="4" />
                            <attribute id="Mystery" value="" type="22" />
                            <attribute id="MysteryAction" value="0" type="1" />
                            <attribute id="MysteryDescription" value="" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="Objective" value="" type="22" />
                            <attribute id="QuestRewardCount" value="0" type="4" />
                            <attribute id="QuestRewardLevel" value="0" type="4" />
                            <attribute id="ReputationGain" value="0" type="4" />
                            <attribute id="StatTriggerGUID" value="" type="22" />
                            <attribute id="Status" value="Default" type="22" />
                        </node>
                    </children>
                </node>
                <node id="Quest">
                    <attribute id="CategoryID" value="EE_Tutorial" type="22" />
                    <attribute id="MainQuest" value="0" type="19" />
                    <attribute id="QuestBroadcastLevel" value="2" type="1" />
                    <attribute id="QuestID" value="EE_Initiative" type="22" />
                    <attribute id="QuestTitle" value="Инициатива и бонус Готовность" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                    <attribute id="Shareable" value="1" type="19" />
                    <attribute id="SortingPriority" value="0" type="4" />
                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value='&quot;Готовность&quot; в Epic Encounters - это поощрение за высокую инициативу в бою.&lt;br&gt;&lt;br&gt;В течение боя, если у персонажа (у любого в бою) больше инициативы, чем у предыдущего в очереди вражеского (у существ учитывается инициатива призывателя), то он получает бонус "Готовность", который дает 1 ОД каждый ход, или 2 ОД, если лидерство в инициативе будет сохраняться и на следующих ходах (ОД добавляются сверх лимита).&lt;br&gt;&lt;br&gt;Бонус "Готовность" недоступен для первоходящего персонажа, это можно изменить с помощью таланта "Ранняя пташка".' handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
