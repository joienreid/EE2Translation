                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value='Если персонаж в бою был воскрешен, но при этом он уже ходил в этом раунде, то он получает эффект "Слабость после воскрешения", который делает его недееспособным на 1 ход.&lt;br&gt;&lt;br&gt;&lt;font size=&quot;6&quot;&gt;Давайте, поабузьте воскрешение.&lt;/font&gt;' handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
