                    <attribute id="QuestBroadcastLevel" value="2" type="1" />
                    <attribute id="QuestID" value="EE_Ascension" type="22" />
                    <attribute id="QuestTitle" value="Вознесение" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                    <attribute id="Shareable" value="1" type="19" />
                    <attribute id="SortingPriority" value="0" type="4" />
                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value='Вознесение - это новая система прокачки, которая добавляет значительное разнообразие в сборки персонажей и варианты взаимодействия между членами вашего отряда. Получить доступ к меню Вознесения можно при использовании способности «Медитация». Каждый уровень персонажи получают 1 "очко Вознесения" (также вы получите 5 доп. очков за некоторые "сюжетные моменты": получение способности «Благословение»; обнаружение убежища искателей (святилише Амадии); получение способности «Спиритизм»; «Вытягивание Истока»; и второго очка Истока).&lt;br&gt;&lt;br&gt;Вознесение состоит из пяти "аспектов": Force, Life, Entropy, Form и Inertia. При двойном нажатии на один из них, вам откроются 12 находяшихся в аспекте созвездий, которые можно условно разделить на 1, 2 и 3 уровни. Созвездия состоят из "ячеек", на которые вы и тратите "очки Вознесения". Для получения начального доступа к созвездиям вам необходимо иметь как минимум 1 вложенное в "аспект" очко, которое по-началу вы можете найти в основном меню Вознесения (The Core). &lt;br&gt;&lt;br&gt;Соседствующие друг с другом "аспекты" разделяют похожие бонусы и требования для созвездий.&lt;br&gt;&lt;br&gt;Сбросить и перераспределить "очки Вознесения" можно в любой момент (кроме боя), никаких штрафов вы не получите.' handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="DevComment" value="" type="22" />
                            <attribute id="Gain" value="0" type="4" />
                            <attribute id="Mystery" value="" type="22" />
                            <attribute id="MysteryAction" value="0" type="1" />
                            <attribute id="MysteryDescription" value="" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="Objective" value="" type="22" />
