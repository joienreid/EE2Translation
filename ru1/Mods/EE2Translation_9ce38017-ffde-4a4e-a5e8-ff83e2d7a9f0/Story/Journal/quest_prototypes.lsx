                <node id="Quest">
                    <attribute id="CategoryID" value="EE_Tutorial" type="22" />
                    <attribute id="MainQuest" value="0" type="19" />
                    <attribute id="QuestBroadcastLevel" value="2" type="1" />
                    <attribute id="QuestID" value="EE_Runes" type="22" />
                    <attribute id="QuestTitle" value="Руны" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                    <attribute id="Shareable" value="1" type="19" />
                    <attribute id="SortingPriority" value="0" type="4" />
                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value="Epic Encounters добавляет 19 новых видов рун и также меняет некоторые особенности их использования. Оправы для рун удалены. Смастерить малую руну можно при объединении ее материала с пыльцой пикси. Дальнейшее объединение осталось все таким же, пыльца пикси и две руны меньшего размера.&lt;br&gt;- В один элемент снаряжения нельзя вставить больше одной руны одного вида и также два оружия не могут иметь одинаковых рун.&lt;br&gt;- Извлекая руны старым способом вы будете их уничтожать. Для безопасного извлечения теперь используется функция Greatforge, а именно Extract Runes/Извлечь руны (для удобства вынесено в контекстное ПКМ меню)." handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="DevComment" value="" type="22" />
                            <attribute id="Gain" value="0" type="4" />
                            <attribute id="Mystery" value="" type="22" />
                            <attribute id="MysteryAction" value="0" type="1" />
                            <attribute id="MysteryDescription" value="" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="Objective" value="" type="22" />
                            <attribute id="QuestRewardCount" value="0" type="4" />
                            <attribute id="QuestRewardLevel" value="0" type="4" />
                            <attribute id="ReputationGain" value="0" type="4" />
