                </node>
                <node id="Quest">
                    <attribute id="CategoryID" value="EE_Tutorial" type="22" />
                    <attribute id="MainQuest" value="0" type="19" />
                    <attribute id="QuestBroadcastLevel" value="2" type="1" />
                    <attribute id="QuestID" value="EE_Reactions" type="22" />
                    <attribute id="QuestTitle" value="Реакции" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                    <attribute id="Shareable" value="1" type="19" />
                    <attribute id="SortingPriority" value="0" type="4" />
                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value="Реакции это новая система, которая значительно улучшает и расширяет взаимодействие между членами вашего отряда.&lt;br&gt;&lt;br&gt;Реакции и бонусы к ним доступны в окне Вознесения, множестве Артефактов и некоторых способностях. Персонаж может применить реакцию только вне своего хода. По умолчанию на них тратится по 1 ОД (от остаточных после хода), но есть возможность получить значительное количество бесплатных зарядов (самый доступный способ - талант Оппортунист).&lt;br&gt;&lt;br&gt;Реакции применяются при выполнении условий их активации, наличии свободных ОД или бесплатных зарядов. Бонусы к реакциям, которые вы будете прокачивать можно условно разделить на 'Активаторы' (при каких условиях активируются) и 'Мутаторы' (эффекты при активации)." handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="DevComment" value="" type="22" />
                            <attribute id="Gain" value="0" type="4" />
