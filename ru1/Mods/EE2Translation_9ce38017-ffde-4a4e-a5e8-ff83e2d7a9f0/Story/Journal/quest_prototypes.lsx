                            <attribute id="StatTriggerGUID" value="" type="22" />
                            <attribute id="Status" value="Default" type="22" />
                        </node>
                    </children>
                </node>
                <node id="Quest">
                    <attribute id="CategoryID" value="EE_Tutorial" type="22" />
                    <attribute id="MainQuest" value="0" type="19" />
                    <attribute id="QuestBroadcastLevel" value="2" type="1" />
                    <attribute id="QuestID" value="EE_Dodging" type="22" />
                    <attribute id="QuestTitle" value="Несколько заметок по игре" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                    <attribute id="Shareable" value="1" type="19" />
                    <attribute id="SortingPriority" value="0" type="4" />
                    <children>
                        <node id="QuestState">
                            <attribute id="Achievement" value="" type="22" />
                            <attribute id="Act" value="0" type="4" />
                            <attribute id="Description" value="Сложность игры - &quot;Тактика&quot;, пресет EE2 - &quot;Impossible&quot;, группа из 4х персонажей - это вариант игры, вокруг которого автор аддона создавал весь баланс.&lt;br&gt;&quot;Доблесть&quot; не рекомендуется в большей степени по техническим причинам: автосохранения при смерти персонажей могут прервать вам, например, реакцию, что может оказать влияние на бой, ну и также это будет чертовски сложно (скорее душно)!&lt;br&gt;&quot;Волки-одиночки&quot; не рекомендованы в связи с тем, что они облегчат игровой процесс, и при этом также будут значительно ограничивать вас в выборе билдов (вся уникальная фишка билдостроения в EE2 заключается в комбинациях между сопартийцами).&lt;br&gt;&quot;Impossible&quot; - это предпоследний и сбалансированный пресет сложности, максимальный пресет &quot;DoNotPickThis&quot; - несбалансирован, это сложность ради сложности, которая еще больше ограничит возможные сборки ваших персонажей: любой враг может уничтожить вас за пару действий, и игроки, банально, не могут в таких условиях реализовать интересные комбинации, все сведется к сидению в кустах и простому набору сопротивлений.&lt;br&gt;&lt;br&gt;Не пропускайте бой с Даллис у ворот форта, иначе лишитесь уникального зелья, также не приходите в башню Бракка вплоть до завершения всех прочих боев на острове (9 уровень).&lt;br&gt;&lt;br&gt;&quot;Боссы&quot; - ваша основная цель и мотивация проводить бои. С персонажей с подобным статусом вы и получаете все основные ресурсы, &quot;Артефакты&quot; и экипировку. Теперь вы можете зачищать всю карту с чуть более чистой совестью, у многих ранее не враждебных нпс теперь будет этот статус, который, в свою очередь также является значительным усилением.&lt;br&gt;Добыча с &quot;Боссов&quot; различается по своей величине (Mini, Mega boss...), в настройках Epip вы можете поставить соответствующее отображение, и при наведении и нажатии Shift, вы будете видеть вариант выпадаемого лута, с возможностью получения &quot;Артефактов&quot;.&lt;br&gt;&lt;br&gt;Использование &quot;Провокации&quot; теперь является важнейшей частью любой битвы. Правильный &quot;аггро-менеджмент&quot; обеспечит основу выживания вашей группы.&lt;br&gt;&quot;Провокация&quot; переработана, и не является бесполезной механикой, как в ванилле. Наложение &quot;провокации&quot; расширено, и теперь подобный эффект есть у некоторых насыщенных Истоком способностей, в бонусах &quot;Вознесения&quot; и, наверное, самое основное, в таланте &quot;Боец-провокатор&quot;, который позволит вам провоцировать врагов большей частью способностей &quot;Военного дела&quot;. Теперь противники действительно бьют провоцирующего персонажа, но это не значит, что они ограничены в своих действиях. Если вы будете стоять рядом со своим &quot;танком&quot;, то будьте уверены, у врага найдется областное заклинание, которое нанесет урон всем вокруг (основное условие то исполняется, враг наносит урон провоцирующему персонажу).&lt;br&gt;Есть несколько исключений, при которых противник может игнорировать провоцирующего персонажа: это &quot;Оковы боли&quot;, &quot;Отражающий барьер&quot;(в очень редких случаях) и некоторые скриптовые моменты в боях. Также исключением может являться нахождение вне зоны досягаемости противника, где враг не может вас никак достать.&lt;br&gt;&lt;br&gt;Скрытность, использование реакций Celestial, Benevolence и прочих бонусов &quot;Вознесения&quot;, уровневых эффектов, прокачка телосложения, высокое уклонение, а также правильное позиционирование могут обеспечить выживание остальной части вашей группы.&lt;br&gt;В начале боя враги всегда поворачиваются на персонажа в скрытности, и, соответственно, выводят из нее, занимайте более укромные позиции (это еще особенность со времен ваниллы). Если вы остались в бою совсем один, то скрытность вас не спасет, враги рано или поздно все-таки найдут вас.&lt;br&gt;Уровневый эффект &quot;Subjugated&quot; является противоположностью провокации, враги будут вас игнорировать, если вы наложили этот эффект.&lt;br&gt;Использование скрытности облегчается ее значительным удешевлением (вплоть до 1 ОД или вообще бесплатных бонусов), а также применением уровневых эффектов &quot;Dazzled&quot; и &quot;Terrified&quot;, которые &quot;ослепляют&quot; противников, так, что они не смогут вас обнаружить. Если вы хотите надежно выживать до вашего хода, то ваш выбор талант &quot;Трикстер&quot;, который дает вам полноценную невидимость в начале боя, а после, автоматически вводит вас в скрытность в конце хода (но он не вполне удобен, если вы хотите наносить урон со скрытности, так как она всегда будет спадать в начале хода)." handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="DevComment" value="" type="22" />
                            <attribute id="Gain" value="0" type="4" />
                            <attribute id="Mystery" value="" type="22" />
                            <attribute id="MysteryAction" value="0" type="1" />
                            <attribute id="MysteryDescription" value="" handle="ls::TranslatedStringRepository::s_HandleUnknown" type="28" />
                            <attribute id="Objective" value="" type="22" />
                            <attribute id="QuestRewardCount" value="0" type="4" />
                            <attribute id="QuestRewardLevel" value="0" type="4" />
                            <attribute id="ReputationGain" value="0" type="4" />
                            <attribute id="StatTriggerGUID" value="" type="22" />
                            <attribute id="Status" value="Default" type="22" />
                        </node>
                    </children>
                </node>
            </children>
        </node>
    </region>
</save>
